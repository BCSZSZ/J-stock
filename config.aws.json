    "filters": {
      "mode": "single",
      "default": {
        "enabled": false
      },
      "variants": {}
    },
    "default_position_file": "s3://jsa-prod-ops/evaluation/evaluation-position.json",
    "default_profile_names": ["p7x018"]
  },
  "overlays": {
