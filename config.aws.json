    "max_position_pct": 0.2,
    "buy_threshold": 65,
    "strategy_groups": [
      {
        "id": "group_main",
        "name": "main",
        "initial_capital": 3000000,
        "entry_strategy": "MACDCrossoverStrategy",
        "exit_strategy": "MVX_N3_R3p25_T1p6_D21_B20p0"
      }
    ]
