{
  "data": {
    "monitor_list_file": "s3://jsa-prod-ops/config/monitor_list.json",
    "data_dir": "/tmp/data"
  },
  "runtime": {
    "mode": "aws",
    "storage_backend": "s3",
    "state_backend": "dynamodb"
  },
  "backtest": {
    "start_date": "2021-01-01",
    "end_date": "2026-01-08",
    "starting_capital_jpy": 5000000,
    "output_dir": "s3://jsa-prod-ops/backtest_results"
  },
  "portfolio": {
    "max_positions": 8,
    "max_position_pct": 0.2,
    "min_position_pct": 0.05,
    "output_dir": "s3://jsa-prod-ops/portfolio_backtest_results"
  },
  "lot_sizes": {
    "1321": 1,
    "1343": 1,
    "default": 100
  },
  "default_strategies": {
    "entry": "SimpleScorerStrategy",
    "exit": "MVX_N3_R3p25_T1p6_D21_B20p0"
  },
  "evaluation": {
    "output_dir": "s3://jsa-prod-ops/strategy_evaluation",
    "default_entry_strategies": ["MACDCrossoverStrategy"],
    "default_exit_strategies": ["MVX_N9_R3p6_T1p7_D18_B20p0"],
