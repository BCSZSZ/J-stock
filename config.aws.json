    "history_file": "s3://jsa-prod-ops/state/trade_history.json",
    "cash_history_file": "s3://jsa-prod-ops/state/cash_history.json",
    "fetch_universe_file": "s3://jsa-prod-ops/state/fetch_universe.json",
    "sector_pool_file": "s3://jsa-prod-ops/universe/sector_pool",
