{
  "data": {
    "monitor_list_file": "data/monitor_list.json",
    "data_dir": "data"
  },
  "runtime": {
    "mode": "local",
    "storage_backend": "local_fs",
    "state_backend": "json"
  },
  "backtest": {
    "start_date": "2021-01-01",
    "end_date": "2026-01-08",
    "starting_capital_jpy": 5000000,
    "output_dir": "backtest_results"
  },
  "portfolio": {
    "starting_capital_jpy": 9000000,
    "position_sizing_mode": "atr",
    "atr_position_sizing": {
      "risk_per_trade_pct": 0.006,
      "atr_stop_multiple": 2.0,
      "min_position_value_jpy": 0
    },
    "max_positions": 7,
    "max_position_pct": 0.18,
    "output_dir": "portfolio_backtest_results"
  },
  "lot_sizes": {
    "1321": 1,
    "1343": 1,
    "default": 100
  },
  "default_strategies": {
    "entry": "SimpleScorerStrategy",
    "exit": "MVX_N9_R3p4_T1p6_D18_B20p0"
  },
  "capacity_regime": {
    "version": "2026-05-v1",
    "equity_window_days": 20,
    "turnover_field": "Turnover_Median_20",
    "tiers": [
      {
        "name": "tier0",
        "max_equity_jpy": 15000000,
        "max_positions": 7,
        "max_position_pct": 0.18,
        "participation_cap_pct": 0.02,
        "min_turnover_20_jpy": 500000000
      },
      {
        "name": "tier1",
        "max_equity_jpy": 40000000,
        "max_positions": 10,
        "max_position_pct": 0.12,
        "participation_cap_pct": 0.015,
        "min_turnover_20_jpy": 800000000
      },
      {
        "name": "tier2",
        "max_equity_jpy": 100000000,
        "max_positions": 14,
        "max_position_pct": 0.08,
        "participation_cap_pct": 0.01,
        "min_turnover_20_jpy": 1200000000
      },
      {
        "name": "tier3",
        "max_equity_jpy": 250000000,
        "max_positions": 18,
        "max_position_pct": 0.055,
        "participation_cap_pct": 0.0075,
        "min_turnover_20_jpy": 2500000000
      },
      {
        "name": "tier4",
        "max_equity_jpy": null,
        "max_positions": 20,
        "max_position_pct": 0.05,
        "participation_cap_pct": 0.005,
        "min_turnover_20_jpy": 5000000000
      }
    ]
  },
  "evaluation": {
    "output_dir": "strategy_evaluation",
    "default_entry_strategies": [
      "MACDCrossoverStrategy"
    ],
    "default_exit_strategies": [
      "MVX_N9_R3p6_T1p7_D18_B20p0"
    ],
    "exit_confirmation_days": 2,
    "capacity_regime_mode": "off",
    "include_continuous": false,
    "filters": {
      "mode": "single",
      "default": {
        "enabled": true,
        "require_ema_bull_stack": false,
        "rsi_min": null,
        "rsi_max": null,
        "atr_price_min": 0.015,
        "atr_price_max": 0.03,
        "min_price": null
      },
      "variants": {
        "f01_base": {
          "enabled": true,
          "require_ema_bull_stack": true,
          "rsi_min": 55,
          "rsi_max": 75,
          "atr_price_min": 0.015,
          "atr_price_max": 0.04,
          "min_price": 1000
        },
        "f02_rsi_tight": {
          "enabled": true,
          "require_ema_bull_stack": true,
          "rsi_min": 58,
          "rsi_max": 70,
          "atr_price_min": 0.015,
          "atr_price_max": 0.04,
          "min_price": 1000
        }
      }
    },
    "default_position_file": "evaluation-position-atr.json",
    "default_profile_names": [
      "atr_risk0p6_n2"
    ]
  },
  "overlays": {
    "enabled": false,
    "active": [
      "SectorBreadthOverlay"
    ],
    "SectorBreadthOverlay": {
      "metrics_file": "data/features/sector_daily_metrics.parquet",
      "snapshot_dir": "data/metadata/sector_overlay",
      "risk_on_target_exposure": 1.0,
      "neutral_target_exposure": 0.8,
      "risk_off_target_exposure": 0.55,
      "block_new_entries_when_risk_off": true,
      "enable_exit_overrides": true
    },
    "RegimeOverlay": {
      "benchmark": "TOPIX",
      "ema_window": 200,
      "vol_lookback": 20,
      "vol_threshold": 0.22,
      "risk_on_target_exposure": 1.0,
      "risk_off_target_exposure": 0.4,
      "block_new_entries_when_off": false
    }
  },
  "stock_pools": {
    "catalog_file": "stock_pools.example.json"
  },
  "production": {
    "monitor_list_file": "data/production_monitor_list.json",
    "fetch_universe_file": "output/state/fetch_universe.json",
    "sector_pool_file": "G:/My Drive/AI-Stock-Sync/universe/sector_pool",
    "state_file": "output/state/production_state.json",
    "signal_file_pattern": "output/signals/{date}.json",
    "report_file_pattern": "output/reports/{date}.md",
    "history_file": "output/state/trade_history.json",
    "cash_history_file": "output/state/cash_history.json",
    "sbi_history_dir": "G:/My Drive/AI-Stock-Sync/historySBI",
    "max_positions_per_group": 8,
    "max_position_pct": 0.18,
    "position_sizing_mode": "atr",
    "atr_position_sizing": {
      "risk_per_trade_pct": 0.006,
      "atr_stop_multiple": 2.0,
      "min_position_value_jpy": 0
    },
    "capacity_regime_mode": "off",
    "buy_threshold": 65,
    "momentum_exhaustion_filter": {
      "enabled": true,
      "mode": "shadow",
      "threshold_method": "absolute",
      "max_score": 4.0
    },
    "industry_filter": {
      "enabled": true,
      "mode": "enforce",
      "max_buy_per_industry_per_day": 1,
      "max_total_positions_per_industry": 3,
      "reference_file": "data/jpx_final_list.csv"
    },
    "strategy_groups": [
      {
        "id": "group_main",
        "name": "main",
        "initial_capital": 9000000,
        "entry_strategy": "MACDCrossoverStrategy",
        "exit_strategy": "MVX_N9_R3p4_T1p6_D18_B20p0"
      }
    ],
    "ops_s3_prefix": "s3://YOUR_BUCKET/prod/ops"
  }
}
